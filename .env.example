# Configuración de Biodiversidad en Cifras.
# Copia este archivo a `.env` y ajusta lo que necesites. Todas las variables
# tienen un valor por defecto razonable: la app arranca sin ningún `.env`.
# El archivo `.env` NO se versiona (está en .gitignore); este `.env.example` sí.

# === Servidor ==============================================================
# Puerto en el que escucha la app (sirve la API y el frontend en uno solo).
PORT=3001

# Marca el entorno de ejecución. Usa `production` en despliegue.
# SIBDATA_ENV=production

# === Base de datos =========================================================
# Ruta del archivo DuckDB que genera la semilla (`deno task seed`).
# SIBDATA_DB_PATH=data/sibdata.duckdb

# Abre la base en modo solo-lectura (útil si varios procesos la comparten).
# SIBDATA_DB_READONLY=1

# === Semilla / canalización de datos =======================================
# Detiene la construcción si la validación de estructura de los datos de
# insumo falla (en vez de solo advertir). Recomendado en despliegues.
# SIBDATA_STRICT_VALIDATE=1

# Argumentos para la semilla al construir la imagen Docker — elige el corte
# de datos sin editar archivos. Lo lee docker-compose.yml.
#   SEED_ARGS=--gitlab-date=2026-05-31
SEED_ARGS=

# === Fuentes de datos ======================================================
# Todas son OPCIONALES: por defecto apuntan a los repositorios públicos
# actuales. Defínelas solo para apuntar la semilla a otra fuente sin tocar el
# código. Las banderas de `deno task seed` tienen prioridad sobre estas.

# Corte de los datos de GitLab (excluyentes entre sí):
#   SIBDATA_GITLAB_DATE=2026-05-31      # corte por fecha (= --gitlab-date)
#   SIBDATA_GITLAB_REF=main             # rama/etiqueta/SHA (= --gitlab-ref)

# Repositorio GitLab de los TSV (por defecto: el repo público del SiB):
#   SIBDATA_GITLAB_PROJECT=https://gitlab.com/sib-colombia/cifras-biodiversidad
#   SIBDATA_GITLAB_PROJECT_ID=sib-colombia/cifras-biodiversidad
#   SIBDATA_GITLAB_DATA_PATH=db-cifras-sib

# Hojas de cálculo de Google (públicas) con textos/indicadores complementarios:
#   SIBDATA_SHEET_DICTIONARY_ID=<id-de-la-hoja-de-diccionario>
#   SIBDATA_SHEET_TEXTOS_ID=<id-de-la-hoja-de-textos>

# Build context exclusions. Keep the context small AND correct — the host
# node_modules / DuckDB are arm64/mac artifacts; the linux image must build
# its own. Everything here is regenerated inside the builder stage.

.git
.gitignore

# Host-built deps (wrong arch) — Deno re-creates these in the builder.
node_modules
packages/web/node_modules
packages/*/node_modules

# Build outputs — regenerated by `deno task build:web`.
packages/web/dist
.vite

# DuckDB — reseeded inside the image (rebuild-on-deploy model).
**/*.duckdb
**/*.duckdb.wal

# Downloaded / generated data (gitignored upstream too).
packages/db/data-raw/downloads
packages/db/data-raw/db-cifras-sib
cartography/downloads
tmp

# Secrets — never bake into the image. Pass at runtime.
.env
.env.local

# Editor / OS cruft
.DS_Store
**/.DS_Store
.Rproj.user
